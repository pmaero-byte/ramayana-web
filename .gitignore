# Unity generated folders
Library/
Logs/
Temp/
UserSettings/
obj/

# Unity build outputs
Build/
Builds/
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/

# Unity asset meta data should only be ignored when the corresponding asset is also ignored
!/Assets/**/*.meta

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache directory
.vs/

# Gradle cache directory
.gradle/

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
# Note: *.csproj and *.sln are intentionally NOT ignored — RamayanaPS5
# commits Assembly-CSharp.csproj + Assembly-CSharp-Editor.csproj +
# Ramayana.EditMode.Tests.csproj + RamayanaPS5.slnx as canonical Mono
# build entry points (matches Yuddhakanta commit 2c51349).
*.unityproj
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated build scripts
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# macOS
.DS_Store

# Local plans
.hermes/plans/

# Session-resume prompts (local continuation docs, never commit)
.hermes/prompts/

# Local config
.vscode/_archive/

# VSCode workspace settings
.vscode/

# Unity performance test artifacts
Assets/Resources/PerformanceTestRunInfo.json
Assets/Resources/PerformanceTestRunSettings.json
.omo/
Assets/Tests/
